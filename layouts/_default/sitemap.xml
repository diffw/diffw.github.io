{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{ range .Data.Pages }}
    {{ if not (or (eq .Kind "taxonomy") (eq .Kind "term")) }}
      {{ $xDefaultLang := lower (site.Param "i18n.xDefaultLang" | default "en") }}
      {{ $xDefaultLangBase := replaceRE "-.*$" "" $xDefaultLang }}
      {{ $xDefault := .Permalink }}
      {{ range .AllTranslations }}
        {{ $translationLang := lower .Language.Lang }}
        {{ $translationCode := lower (.Language.LanguageCode | default .Language.Lang) }}
        {{ $translationBase := replaceRE "-.*$" "" $translationCode }}
        {{ if or (eq $translationLang $xDefaultLang) (eq $translationCode $xDefaultLang) (eq $translationBase $xDefaultLang) (eq $translationLang $xDefaultLangBase) (eq $translationCode $xDefaultLangBase) }}
          {{ $xDefault = .Permalink }}
        {{ end }}
      {{ end }}
      <url>
        <loc>{{ .Permalink }}</loc>
        {{ if not .Lastmod.IsZero }}
          <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
        {{ end }}
        {{ range .AllTranslations }}
          <xhtml:link
            rel="alternate"
            hreflang="{{ .Language.LanguageCode | default .Language.Lang }}"
            href="{{ .Permalink }}" />
        {{ end }}
        <xhtml:link
          rel="alternate"
          hreflang="x-default"
          href="{{ $xDefault }}" />
      </url>
    {{ end }}
  {{ end }}
</urlset>
